# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Supabase (used by app/api/leads/route.ts)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay (used by app/api/razorpay/create-order/route.ts)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Public payment link fallback, shown until the Razorpay order-creation API is wired up
NEXT_PUBLIC_PAYMENT_LINK=https://rzp.io/l/YOUR-PAYMENT-LINK
