# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Supabase (used by app/api/leads/route.ts via lib/supabase.ts)
# The publishable key is safe to expose (subject to RLS) — the `leads` table
# has RLS enabled with an INSERT-only policy for the anon role, see README.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Razorpay (used by app/api/razorpay/create-order/route.ts AND
# app/api/payment/verify/route.ts — the latter verifies the Payment Link
# redirect signature and fetches the authoritative charged amount)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Public payment link fallback, shown until the Razorpay order-creation API is wired up
NEXT_PUBLIC_PAYMENT_LINK=https://rzp.io/l/YOUR-PAYMENT-LINK

# Meta Conversions API (used by lib/metaCapi.ts, called from
# app/api/payment/verify/route.ts). Generate a System User access token in
# Meta Events Manager > Data Sources > [your Pixel] > Settings > Conversions
# API > "Generate access token". Without this set, the server-side Purchase
# event is skipped (logged, not sent) — the browser Pixel event still fires.
META_CAPI_ACCESS_TOKEN=

# Optional — only needed if your Conversions API dataset id differs from the
# Pixel id (913277347759939, hardcoded in lib/constants.ts since it's public
# anyway). Leave unset unless Meta gave you a distinct CAPI Gateway dataset.
META_DATASET_ID=
